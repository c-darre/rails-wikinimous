<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <h1 class="card-title"><%= @article.title %></h1>
    <hr>
    <div class="card-text fs-5">
      <%= simple_format(@article.content) %>
    </div>
  </div>
</div>

<%= link_to "Edit", edit_article_path(@article), class: "btn btn-warning" %>
<%= link_to "Delete", article_path(@article), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger ms-2" %>
<%= link_to "Back", articles_path, class: "btn btn-secondary ms-2" %>
